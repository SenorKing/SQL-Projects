from flask import Flask, render_template, request, redirect, url_for, session
import pymysql

logged_in = None
app = Flask(__name__)

def get_password():
    return 'Febrero26'

def execute_query(sql, db):
    password = get_password()
    conn = pymysql.connections.Connection(host="localhost", user="root", passwd=password, db=db)

    cursor = conn.cursor()
    cursor.execute(sql)
    rows = cursor.fetchall()
    conn.close()
    return rows


def run_query(db, sql):
    password = get_password()
    conn = pymysql.connections.Connection(host="localhost", user="root", passwd=password, db=db)

    try:
        cursor = conn.cursor()
        print(sql)
        cursor.execute(sql)
        rows = cursor.fetchall()
        headers = [desc[0] for desc in cursor.description]
        data = [[str(col) for col in row] for row in rows]
    except:
        print("Error while running query", sql)
        # undo the changes that you made
        conn.close()
        return []
    conn.close()
    return headers, data


@app.route('/')
def hello_world():  # put application's code here
    return 'Hello World!'

@app.route('/name/<name>')
