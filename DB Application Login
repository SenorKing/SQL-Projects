    return f'Hello {name}!'

@app.route('/login', methods=['POST', 'GET'])
def login():
    global logged_in
    print("In login")
    typed_name = request.form['name']
    typed_id = request.form['id']
    typed_role = request.form['role']
    print(typed_name, typed_id, typed_role)
    query = f"SELECT * FROM {typed_role} WHERE id = '{typed_id}' AND name = '{typed_name}'"
    rows = execute_query(query, 'udb')
    if len(rows) > 0:
        logged_in = typed_name
        return f'{typed_role} {typed_name} has successfully logged in to the system'
    else:
        logged_in = None
        return f'{typed_role} {typed_name} does not exist'

@app.route('/retrieve/<table>')
def retrieve(table=None):
    return retrieve_table(table)


def retrieve_table(table) -> str:
    global logged_in
    if not logged_in:
        return "You are not logged in"
    else:  # get the data
        query = f"SELECT * FROM {table}"
        headers, data = run_query("udb", query)
        return render_template('results.html', headers=headers, data=data)


@app.route('/table/', methods=['POST', 'GET'])
def table():
    table_name = request.form['table']
    return retrieve_table(table_name)

if __name__ == '__main__':
    app.run()
