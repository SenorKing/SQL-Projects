/* Create view v_everything*/
CREATE OR REPLACE VIEW v_everything AS (
		SELECT 3NF_book.title, 3NF_book.author, 3NF_author.nationality AS author_nationality, 3NF_book.pages,
			3NF_book.thickness, 3NF_publisher.publisher, 3NF_publisher.country AS publisher_country, 3NF_book.genre_id, 3NF_genre.genre_name 
		FROM 3NF_book 
        JOIN 3NF_price ON 3NF_book.title = 3NF_price.book_title
        JOIN 3NF_author ON 3NF_book.author = 3NF_author.author
        JOIN 3NF_publisher ON 3NF_book.publisher = 3NF_publisher.publisher
        JOIN 3NF_genre ON 3NF_book.genre_id = 3NF_genre.genre_id
) ;

SELECT * FROM v_everything;




